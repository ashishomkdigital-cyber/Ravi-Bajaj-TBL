<section class="timeless-creations">
  <div class="tc-container">

    <!-- Top Row -->
    <div class="tc-top">

      <!-- Left Video -->
      <div class="tc-video">
        {% if section.settings.video_1 != blank %}
          {{ section.settings.video_1 | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
        {% endif %}
      </div>

      <!-- Center Content -->
      <div class="tc-content">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>

      <!-- Right Image -->
      <div class="tc-image">
        {% if section.settings.image_1 != blank %}
          <img src="{{ section.settings.image_1 | image_url: width: 800 }}" alt="">
        {% endif %}
      </div>

    </div>

    <!-- Bottom Row -->
    <div class="tc-bottom">

      <!-- Large Image -->
      <div class="tc-large-image">
        {% if section.settings.image_2 != blank %}
          <img src="{{ section.settings.image_2 | image_url: width: 1200 }}" alt="">
        {% endif %}
      </div>

      <!-- Right Video -->
      <div class="tc-video">
        {% if section.settings.video_2 != blank %}
          {{ section.settings.video_2 | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
        {% endif %}
      </div>

    </div>

    <!-- Button -->
    <div class="tc-button">
      <a class="hover-active-effect" href="{{ section.settings.button_link }}">
        {{ section.settings.button_text }}
      </a>
    </div>

  </div>
</section>


<style>

.timeless-creations{
  padding:80px 20px;
  background:#f6f6f6;
}

.tc-container{
  max-width:1200px;
  margin:auto;
}

.tc-top{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:60px;
  align-items:start;
}

.tc-video video{
  width:100%;
  height:auto;
  display:block;
  aspect-ratio: 9 / 16;
  object-fit: contain;
  max-height: 800px; 
}

.tc-image img{
  width:100%;
  height:auto;
  display:block;
  aspect-ratio: 9 / 16;
  object-fit: cover;
}

.tc-content{
  text-align:center;
  max-width:360px;
  margin:auto;
}

.tc-content h2{
  font-size:36px;
  letter-spacing:2px;
  margin-bottom:20px;
}

.tc-content p{
  font-size:15px;
  line-height:1.7;
  color:#444;
}

.tc-bottom{
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:60px;
  margin-top:60px;
  align-items:start;
}

.tc-large-image img{
  width:100%;
  height:675px;
  object-fit: cover;
}

.tc-button{
  text-align:center;
  margin-top:40px;
}

.tc-button a{
  display:inline-block;
  padding:14px 28px;
  border:1px solid #000;
  color:#000;
  text-decoration:none;
  font-size:14px;
  letter-spacing:2px;
}

.tc-button a:hover{
  background:transparent;
  color:#fff;
}

@media(max-width:900px){

  .tc-top{
    grid-template-columns:1fr;
    gap:40px;
  }

  .tc-bottom{
    grid-template-columns:1fr;
  }

}

</style>


{% schema %}
{
  "name": "Timeless Creations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TIMELESS CREATIONS"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Heritage jewellery by Sanjay Gupta has always been the talk-of-the-town as part of our signature collections."
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "Left Video"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "Bottom Right Video"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Right Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Large Bottom Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "DISCOVER HERITAGE JEWELERY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Timeless Creations"
    }
  ]
}
{% endschema %}