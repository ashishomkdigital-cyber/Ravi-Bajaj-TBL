{% style %}
  #CollectionGridSection--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .collection-grid-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .collection-grid-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .collection-grid-section-title {
    font-family: 'Cinzel', serif !important;
    font-size: 28px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #212121;
    margin: 0;
  }

  .collection-grid-3x3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  .collection-grid-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .collection-grid-image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
    background-color: #f5f2ec;
  }

  .collection-grid-image-wrapper img,
  .collection-grid-image-wrapper svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .collection-grid-image-wrapper.aspect-auto img {
    height: auto;
  }

  .collection-grid-image-wrapper svg {
    padding: 30px;
    fill: #a29e97;
  }

  .collection-grid-card:hover .collection-grid-image-wrapper img {
    transform: scale(1.06);
  }

  .collection-grid-title {
    margin-top: 15px;
    text-align: center;
    font-family: 'Cinzel', serif !important;
    font-size: 16px;
    color: #212121;
    text-transform: capitalize;
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .collection-grid-card:hover .collection-grid-title {
    color: #ab8c52;
  }

  @media (max-width: 980px) {
    .collection-grid-3x3 {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .collection-grid-section-title {
      font-size: 22px;
    }
  }

  @media (max-width: 580px) {
    .collection-grid-3x3 {
      grid-template-columns: 1fr 1fr;
      gap: 5px;
    }
    .collection-grid-container {
      padding: 0 20px;
    }
  }
{% endstyle %}

<section id="CollectionGridSection--{{ section.id }}" class="custom-collection-grid-section">
  <div class="collection-grid-container">
    {%- if section.settings.title != blank -%}
      <div class="collection-grid-header">
        <h2 class="collection-grid-section-title">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}

    <div class="collection-grid-3x3">
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = collections[block.settings.collection]
          assign card_title = block.settings.title | default: collection.title | default: "Example Collection"
          assign card_image = block.settings.image | default: collection.image | default: collection.products.first.featured_media.preview_image
          assign card_link = collection.url | default: "#"
        -%}
        
        <a href="{{ card_link }}" class="collection-grid-card" {{ block.shopify_attributes }}>
          <div class="collection-grid-image-wrapper{% if section.settings.aspect_ratio == 'auto' %} aspect-auto{% endif %}" style="{% if section.settings.aspect_ratio != 'auto' %}aspect-ratio: {{ section.settings.aspect_ratio }};{% endif %}">
            {%- if card_image != blank -%}
              <img src="{{ card_image | image_url: width: 800 }}" 
                   alt="{{ card_title | escape }}"
                   loading="lazy"
                   width="{{ card_image.width }}"
                   height="{{ card_image.height }}">
            {%- else -%}
              {%- capture placeholder_num -%}{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
              {{ 'collection-' | append: placeholder_num | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="collection-grid-title">
            {{ card_title }}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid 3x3",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "A SILHOUETTE FOR EVERY OCCASION"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "default": "3/4",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "2/3",
          "label": "Portrait (2:3)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "auto",
          "label": "Adapt to Image"
        }
      ]
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Choose Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Title",
          "info": "Leave blank to use collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid 3x3",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
