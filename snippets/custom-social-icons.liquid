{% liquid
  assign share_url = canonical_url | default: shop.url
  assign share_url_encoded = share_url | url_encode

  assign share_title = shop.name
  if request.page_type == 'product'
    assign share_title = product.title
  elsif request.page_type == 'article'
    assign share_title = article.title
  elsif request.page_type == 'collection'
    assign share_title = collection.title
  elsif page.title != blank
    assign share_title = page.title
  endif
  assign share_title_encoded = share_title | url_encode

  assign pinterest_media = ''
  if request.page_type == 'product' and product.featured_media != blank
    assign pinterest_media = product.featured_media | image_url: width: 1200
  elsif request.page_type == 'article' and article.image != blank
    assign pinterest_media = article.image | image_url: width: 1200
  endif
  assign pinterest_media_encoded = pinterest_media | url_encode
%}

<div class="custom-share-social">
  <a
    class="custom-share-social__item"
    href="https://www.facebook.com/sharer/sharer.php?u={{ share_url_encoded }}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on Facebook"
    title="Share on Facebook"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.6-1.6H17V4.8c-.4-.1-1.4-.1-2.6-.1-2.6 0-4.4 1.6-4.4 4.5V11H7v3h3.4v8h3.1z"/>
    </svg>
  </a>

  <a
    class="custom-share-social__item"
    href="https://x.com/intent/tweet?text={{ share_title_encoded }}&url={{ share_url_encoded }}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on X"
    title="Share on X"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M18.9 2H22l-6.8 7.8L23 22h-6.2l-4.8-6.3L6.5 22H3.4l7.2-8.2L1 2h6.3l4.3 5.7L18.9 2zm-1.1 18h1.7L6.4 3.9H4.6L17.8 20z"/>
    </svg>
  </a>

  <a
    class="custom-share-social__item"
    href="{% if pinterest_media != blank %}https://www.pinterest.com/pin/create/button/?url={{ share_url_encoded }}&media={{ pinterest_media_encoded }}&description={{ share_title_encoded }}{% else %}https://www.pinterest.com/pin/create/button/?url={{ share_url_encoded }}&description={{ share_title_encoded }}{% endif %}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on Pinterest"
    title="Share on Pinterest"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M12 2C6.477 2 2 6.477 2 12c0 4.237 2.635 7.85 6.356 9.305-.088-.79-.167-2.003.035-2.867.183-.781 1.18-4.975 1.18-4.975s-.3-.602-.3-1.492c0-1.397.81-2.441 1.819-2.441.857 0 1.27.643 1.27 1.414 0 .861-.548 2.148-.831 3.341-.237.999.5 1.814 1.484 1.814 1.78 0 3.148-1.876 3.148-4.584 0-2.396-1.722-4.072-4.181-4.072-2.848 0-4.523 2.136-4.523 4.345 0 .861.331 1.785.744 2.286.082.1.094.188.07.289-.076.319-.245 1-.278 1.14-.043.183-.144.221-.333.133-1.24-.578-2.014-2.394-2.014-3.853 0-3.138 2.28-6.02 6.575-6.02 3.452 0 6.137 2.46 6.137 5.748 0 3.43-2.162 6.19-5.165 6.19-1.008 0-1.957-.525-2.281-1.147l-.62 2.362c-.224.862-.83 1.944-1.236 2.603.931.287 1.92.442 2.945.442 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
    </svg>
  </a>

  <a
    class="custom-share-social__item"
    href="mailto:?subject={{ share_title_encoded }}&body={{ share_url_encoded }}"
    aria-label="Share by email"
    title="Share by email"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M3 5h18a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2zm0 2v.5l9 5.5 9-5.5V7H3zm18 10V9.8l-8.5 5.2a1 1 0 0 1-1 0L3 9.8V17h18z"/>
    </svg>
  </a>

  <button
    type="button"
    class="custom-share-social__item"
    aria-label="Share"
    title="Share"
    onclick="if(navigator.share){navigator.share({title: '{{ share_title | escape }}', url: '{{ share_url }}'}).catch(()=>{});}else{window.open('https://x.com/intent/tweet?text={{ share_title_encoded }}&url={{ share_url_encoded }}','_blank','noopener,noreferrer');}"
  >
    <svg viewBox="0 0 16 16" aria-hidden="true">
      <path fill="currentColor" d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3M11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.5 2.5 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5m-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3m11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3"/>
    </svg>
  </button>
</div>

<style>
  .custom-share-social{
    display:flex;
    align-items:center;
    gap:10px;
    flex-wrap:wrap;
    width:100%;
  }

  .custom-share-social__item{
    width:38px;
    height:38px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    border:1px solid #e5e5e5;
    border-radius:50%;
    background:#fff;
    color:#111;
    text-decoration:none;
    line-height:1;
    cursor:pointer;
    padding:0;
    transition:all .2s ease;
  }

  .custom-share-social__item:hover{
    background:#111;
    color:#fff;
    border-color:#111;
    transform:translateY(-1px);
  }

  .custom-share-social__item svg{
    width:18px;
    height:18px;
    display:block;
    fill:currentColor;
  }

  button.custom-share-social__item{
    appearance:none;
    -webkit-appearance:none;
  }
</style>