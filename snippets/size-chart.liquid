{% assign show_size_chart = false %}
{% assign chart_category = '' %}
{% assign product_collections = product.collections | map: 'handle' %}
{% assign product_title_down = product.title | downcase %}
{% assign product_type_down = product.type | downcase %}

{% if product_collections contains 'gillet' %}
  {% assign chart_category = 'gillet' %}
  {% assign show_size_chart = true %}
{% elsif product_collections contains 'lehenga' %}
  {% assign chart_category = 'lehenga' %}
  {% assign show_size_chart = true %}
{% elsif product_collections contains 'gown' %}
  {% assign chart_category = 'gown' %}
  {% assign show_size_chart = true %}
{% elsif product_collections contains 'jackets' %}
  {% if product_title_down contains 'women' or product_title_down contains 'woman' or product_title_down contains 'ladies' or product_type_down contains 'women' or product_type_down contains 'woman' or product_type_down contains 'ladies' %}
    {% assign chart_category = 'women-jacket' %}
  {% else %}
    {% assign chart_category = 'jacket-mens' %}
  {% endif %}
  {% assign show_size_chart = true %}
{% elsif product_collections contains 'kurta' %}
  {% assign chart_category = 'kurta-navigator' %}
  {% assign show_size_chart = true %}
{% elsif product_collections contains 'shirt' %}
  {% assign chart_category = 'shirt-mens' %}
  {% assign show_size_chart = true %}
{% endif %}

{% if show_size_chart %}
<style>
/* Trigger button */
.size-chart-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    cursor: pointer;
    color: #222;
    font-size: 15px;
    font-weight: 500;
    padding: 0;
    transition: opacity 0.3s;
}

.size-chart-trigger span {
    border-bottom: 1.5px solid currentColor;
    transition: opacity .3s;
}

.size-chart-trigger:hover span {
    opacity: .7;
}

/* Modal container */
.size-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 2147483647;
    padding: 20px;
}

.size-modal.active {
    opacity: 1;
    visibility: visible;
}

/* Modal Content Box */
.size-modal-content {
    width: 100%;
    max-width: 850px;
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    position: relative;
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    animation: popup .3s cubic-bezier(0.34, 1.56, 0.64, 1);
    {% comment %} max-height: 90vh; {% endcomment %}
    max-height: 70vh;
    display: flex;
    flex-direction: column;
}

@keyframes popup {
    from {
        transform: translateY(24px) scale(0.96);
        opacity: 0;
    }
    to {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
}

.close-size-modal {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 36px;
    height: 36px;
    border: none;
    background: #f5f5f5;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: #444;
    transition: all 0.2s ease;
    z-index: 10;
}

.close-size-modal:hover {
    background: #e8e8e8;
    color: #000;
    transform: rotate(90deg);
}

.size-modal h2 {
    font-family: inherit;
    font-size: 24px;
    font-weight: 600;
    color: #111;
    margin: 0 0 24px 0;
}

/* Controls */
.size-modal-controls {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 20px;
}

.unit-switch {
    display: flex;
    background: #f5f5f5;
    border-radius: 50px;
    width: max-content;
    padding: 4px;
}

.unit-switch button {
    border: none;
    background: none;
    padding: 8px 18px;
    cursor: pointer;
    border-radius: 50px;
    font-weight: 600;
    font-size: 13px;
    color: #666;
    transition: all 0.2s ease;
}

.unit-switch button.active {
    background: #111;
    color: #fff;
}

/* Scrollable area for content */
.table-scroll-container {
    flex: 1;
    overflow-y: auto;
    padding-right: 4px;
}

.table-wrapper {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid #eee;
    border-radius: 8px;
    background: #fff;
    margin-bottom: 20px;
}

table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
}

thead {
    background: #111;
    color: #fff;
}

th {
    font-weight: 600;
    padding: 12px 14px;
    text-align: left;
}

th:not(:first-child), td:not(:first-child) {
    text-align: center;
}

th, td {
    padding: 12px 14px;
    border-bottom: 1px solid #eee;
    white-space: nowrap;
}

tbody tr:nth-child(even) {
    background: #fcfcfc;
}

tbody tr:hover {
    background: #f7f7f7;
}

/* Footer Instructions & Disclaimer */
.size-guide-footer {
    border-top: 1px solid #eee;
    padding-top: 20px;
    margin-top: 10px;
}

.size-guide-instructions h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: #111;
}

.instruction-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px 24px;
    margin-bottom: 20px;
}

@media(max-width: 768px) {
    .instruction-grid {
        grid-template-columns: 1fr;
        gap: 8px;
    }
}

.instruction-item {
    font-size: 13px;
    color: #555;
    line-height: 1.4;
}

.instruction-item strong {
    color: #111;
}

.size-guide-disclaimer {
    background: #f9f9f9;
    padding: 14px 16px;
    border-radius: 8px;
    border-left: 3px solid #111;
    font-size: 12.5px;
    color: #555;
    line-height: 1.5;
}

.size-guide-disclaimer p {
    margin: 0 0 8px 0;
}

.size-guide-disclaimer p:last-child {
    margin: 0;
}

.size-guide-disclaimer .tolerance {
    font-weight: 500;
    color: #333;
}

@media(max-width: 640px) {
    .size-modal-content {
        padding: 20px;
    }
    
    .size-modal h2 {
        font-size: 20px;
        margin-bottom: 16px;
    }

    th, td {
        padding: 10px 8px;
        font-size: 13px;
    }
}
</style>

