<style>
/* Trigger */

.size-chart-trigger{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:none;
    border:none;
    cursor:pointer;
    color:#222;
    font-size:15px;
    font-weight:500;
    padding:0;
}

.size-chart-trigger span{
    border-bottom:1.5px solid currentColor;
    transition:.3s;
}

.size-chart-trigger:hover span{
    opacity:.7;
}

/* Modal */

.size-modal{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.55);
    display:flex;
    align-items:center;
    justify-content:center;
    opacity:0;
    visibility:hidden;
    transition:.3s;
    z-index:9999;
    padding:20px;
}

.size-modal.active{
    opacity:1;
    visibility:visible;
}

.size-modal-content{
    width:100%;
    max-width:750px;
    background:#fff;
    border-radius:14px;
    padding:28px;
    position:relative;
    animation:popup .3s ease;
    max-height:90vh;
    overflow:auto;
}

@keyframes popup{
    from{
        transform:translateY(20px);
        opacity:0;
    }
    to{
        transform:translateY(0);
        opacity:1;
    }
}

.close-size-modal{
    position:absolute;
    top:15px;
    right:15px;
    width:36px;
    height:36px;
    border:none;
    background:#f3f3f3;
    border-radius:50%;
    cursor:pointer;
    font-size:26px;
    line-height:1;
}

.size-modal h2{
    margin-bottom:20px;
}

/* Unit Switch */

.unit-switch{
    display:flex;
    background:#f5f5f5;
    border-radius:50px;
    width:max-content;
    padding:4px;
    margin-bottom:25px;
}

.unit-switch button{
    border:none;
    background:none;
    padding:10px 22px;
    cursor:pointer;
    border-radius:50px;
    font-weight:600;
}

.unit-switch button.active{
    background:#111;
    color:#fff;
}

/* Table */

table{
    width:100%;
    border-collapse:collapse;
}

thead{
    background:#111;
    color:#fff;
}

th,td{
    padding:14px;
    text-align:center;
    border-bottom:1px solid #eee;
}

tbody tr:nth-child(even){
    background:#fafafa;
}

@media(max-width:640px){

    .size-modal-content{
        padding:20px;
    }

    th,td{
        padding:10px 6px;
        font-size:14px;
    }

}
</style>
<!-- Size Chart Trigger -->
<button class="size-chart-trigger" id="openSizeChart">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24">
        <path d="M4 6h16v12H4V6Zm3 0v3m3-3v2m3-2v3m3-3v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>

    <span>Size Chart</span>
</button>

<!-- Modal -->
<div class="size-modal" id="sizeModal">

    <div class="size-modal-content">

        <button class="close-size-modal">&times;</button>

        <h2>Size Chart</h2>

        <div class="unit-switch">
            <button class="active" data-unit="inch">Inches</button>
            <button data-unit="cm">Centimeters</button>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Size</th>
                    <th>Chest</th>
                    <th>Waist</th>
                    <th>Hip</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td>XS</td>
                    <td class="measure" data-inch="32">32"</td>
                    <td class="measure" data-inch="26">26"</td>
                    <td class="measure" data-inch="34">34"</td>
                </tr>

                <tr>
                    <td>S</td>
                    <td class="measure" data-inch="34">34"</td>
                    <td class="measure" data-inch="28">28"</td>
                    <td class="measure" data-inch="36">36"</td>
                </tr>

                <tr>
                    <td>M</td>
                    <td class="measure" data-inch="36">36"</td>
                    <td class="measure" data-inch="30">30"</td>
                    <td class="measure" data-inch="38">38"</td>
                </tr>

                <tr>
                    <td>L</td>
                    <td class="measure" data-inch="40">40"</td>
                    <td class="measure" data-inch="34">34"</td>
                    <td class="measure" data-inch="42">42"</td>
                </tr>

                <tr>
                    <td>XL</td>
                    <td class="measure" data-inch="44">44"</td>
                    <td class="measure" data-inch="38">38"</td>
                    <td class="measure" data-inch="46">46"</td>
                </tr>

            </tbody>
        </table>

    </div>

</div>

<script>

const modal = document.getElementById("sizeModal");

document.getElementById("openSizeChart").onclick = () => {
    modal.classList.add("active");
    document.body.style.overflow = "hidden";
};

document.querySelector(".close-size-modal").onclick = closeModal;

modal.onclick = (e) => {
    if (e.target === modal) closeModal();
};

document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
});

function closeModal() {
    modal.classList.remove("active");
    document.body.style.overflow = "";
}

/* Unit Switch */

const buttons = document.querySelectorAll(".unit-switch button");
const measures = document.querySelectorAll(".measure");

buttons.forEach(btn => {

    btn.onclick = () => {

        buttons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");

        const unit = btn.dataset.unit;

        measures.forEach(cell => {

            const inch = parseFloat(cell.dataset.inch);

            if (unit === "inch") {
                cell.textContent = `${inch}"`;
            } else {
                cell.textContent = `${(inch * 2.54).toFixed(1)} cm`;
            }

        });

    };

});</script>