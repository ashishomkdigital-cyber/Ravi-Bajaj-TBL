<script>
const modal = document.getElementById("sizeModal");

document.getElementById("openSizeChart").onclick = () => {
    modal.classList.add("active");
    document.body.style.overflow = "hidden";
};

document.querySelector(".close-size-modal").onclick = closeModal;

modal.onclick = (e) => {
    if (e.target === modal) closeModal();
};

document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
});

function closeModal() {
    modal.classList.remove("active");
    document.body.style.overflow = "";
}

/* Unit Switcher */
const unitButtons = document.querySelectorAll(".unit-switch button");
const measures = document.querySelectorAll(".measure");
const headUnits = document.querySelectorAll(".head-unit");

unitButtons.forEach(btn => {
    btn.onclick = () => {
        unitButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");

        const unit = btn.dataset.unit;

        // Update headers to show current unit
        headUnits.forEach(th => {
            th.textContent = unit === "inch" ? "Measurement (Inches)" : "Measurement (cm)";
        });

        // Convert measurements
        measures.forEach(cell => {
            const inch = parseFloat(cell.dataset.inch);
            if (unit === "inch") {
                const display = cell.dataset.inchDisplay || cell.dataset.inch;
                cell.textContent = display.includes('"') ? display : `${display}"`;
            } else {
                // Convert inch to cm (1 inch = 2.54 cm)
                // Round to 1 decimal place
                cell.textContent = `${(inch * 2.54).toFixed(1)} cm`;
            }
        });
    };
});
</script>
{% endif %}