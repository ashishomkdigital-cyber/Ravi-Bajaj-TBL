{% doc %}
  @prompt
    Create a split two-video section that displays two videos side by side in a 50/50 layout. Each video should support YouTube, Vimeo, or uploaded video files, with individual options for autoplay, muted playback, and loop. Each video panel should have an optional heading and subheading overlay. The section should be responsive (stacking vertically on mobile), with customizable padding and a clean, modern look.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-video-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-split-video-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-split-video-panel-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-split-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    background-color: #000000;
  }

  .ai-split-video-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-split-video-native-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-split-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-split-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-split-video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.text_vertical_alignment }};
    align-items: {{ block.settings.text_horizontal_alignment }};
    padding: 30px;
    pointer-events: none;
    z-index: 2;
  }

  .ai-split-video-overlay-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    max-width: 500px;
  }

  .ai-split-video-heading-{{ ai_gen_id }} {
    margin: 0 0 10px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-split-video-subheading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  @media screen and (max-width: 749px) {
    .ai-split-video-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-split-video-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-split-video-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-split-video-overlay-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<split-video-section-{{ ai_gen_id }} class="ai-split-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-video-container-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      {% liquid
        assign video_url_key = 'video_url_' | append: i
        assign video_file_key = 'video_file_' | append: i
        assign autoplay_key = 'autoplay_' | append: i
        assign muted_key = 'muted_' | append: i
        assign loop_key = 'loop_' | append: i
        assign heading_key = 'heading_' | append: i
        assign subheading_key = 'subheading_' | append: i

        assign video_url = block.settings[video_url_key]
        assign video_file = block.settings[video_file_key]
        assign autoplay = block.settings[autoplay_key]
        assign muted = block.settings[muted_key]
        assign loop = block.settings[loop_key]
        assign heading = block.settings[heading_key]
        assign subheading = block.settings[subheading_key]

        assign video_id = ''
        assign video_type = ''

        if video_url contains 'youtube.com' or video_url contains 'youtu.be'
          assign video_type = 'youtube'
          if video_url contains 'youtu.be/'
            assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
          elsif video_url contains 'watch?v='
            assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first
          elsif video_url contains 'embed/'
            assign video_id = video_url | split: 'embed/' | last | split: '?' | first
          endif
        elsif video_url contains 'vimeo.com'
          assign video_type = 'vimeo'
          assign video_id = video_url | split: 'vimeo.com/' | last | split: '/' | first
        endif
      %}

      <div class="ai-split-video-panel-{{ ai_gen_id }}">
        <div class="ai-split-video-wrapper-{{ ai_gen_id }}">
          {% if video_file != blank %}
            <video
              class="ai-split-video-native-{{ ai_gen_id }}"
              {% if autoplay %}autoplay{% endif %}
              {% if muted %}muted{% endif %}
              {% if loop %}loop{% endif %}
              playsinline
            >
              <source src="{{ video_file }}" type="video/mp4">
            </video>
          {% elsif video_type == 'youtube' and video_id != '' %}
            <iframe
              class="ai-split-video-iframe-{{ ai_gen_id }}"
              src="https://www.youtube.com/embed/{{ video_id }}?{% if autoplay %}autoplay=1&{% endif %}{% if muted %}mute=1&{% endif %}{% if loop %}loop=1&playlist={{ video_id }}&{% endif %}controls=1&rel=0&modestbranding=1"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          {% elsif video_type == 'vimeo' and video_id != '' %}
            <iframe
              class="ai-split-video-iframe-{{ ai_gen_id }}"
              src="https://player.vimeo.com/video/{{ video_id }}?{% if autoplay %}autoplay=1&{% endif %}{% if muted %}muted=1&{% endif %}{% if loop %}loop=1&{% endif %}controls=1"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
            ></iframe>
          {% else %}
            <div class="ai-split-video-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
            </div>
          {% endif %}

          {% if heading != blank or subheading != blank %}
            <div class="ai-split-video-overlay-{{ ai_gen_id }}">
              <div class="ai-split-video-overlay-content-{{ ai_gen_id }}">
                {% if heading != blank %}
                  <h2 class="ai-split-video-heading-{{ ai_gen_id }}">{{ heading }}</h2>
                {% endif %}
                {% if subheading != blank %}
                  <p class="ai-split-video-subheading-{{ ai_gen_id }}">{{ subheading }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</split-video-section-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitVideoSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-split-video-native-{{ ai_gen_id }}');
        this.setupVideoObserver();
      }

      setupVideoObserver() {
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              const video = entry.target;
              if (entry.isIntersecting) {
                if (video.hasAttribute('autoplay')) {
                  video.play().catch(() => {});
                }
              } else {
                video.pause();
              }
            });
          }, { threshold: 0.5 });

          this.videos.forEach((video) => {
            observer.observe(video);
          });
        }
      }
    }

    customElements.define('split-video-section-{{ ai_gen_id }}', SplitVideoSection{{ ai_gen_id }});
  })();
</script>

