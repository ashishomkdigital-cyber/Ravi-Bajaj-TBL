{"sections":{"section-divider":{"type":"section-divider","settings":{"show_line":true,"width":"wrapper--full","color_scheme":"","padding_top":0,"padding_bottom":0}},"main-page":{"type":"main-page","disabled":true,"settings":{"subheading":"","show_title":true,"heading_font_size":"heading-medium","show_content":true,"text_font_size":"body-small","align_text":"text-left","width":"wrapper","color_scheme":"","padding_top":50,"padding_bottom":50,"heading_tag":"automatic"}},"section_custom_code_wrWknE":{"type":"section-custom-code","name":"Custom code","settings":{"code":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\n<style>\n*{\n    margin:0;\n    padding:0;\n    box-sizing:border-box;\n    font-family:Arial,Helvetica,sans-serif;\n}\n\n.size-chart{\n    max-width:700px;\n    margin:40px auto;\nmargin-top:5.5rem;\n}\n\n.unit-switch{\n    display:flex;\n    justify-content:center;\n    margin-bottom:20px;\n    background:#f3f3f3;\n    border-radius:50px;\n    padding:4px;\n    width:max-content;\n    margin-inline:auto;\n}\n\n.unit-switch button{\n    border:none;\n    background:transparent;\n    padding:10px 24px;\n    cursor:pointer;\n    border-radius:50px;\n    font-size:15px;\n    font-weight:600;\n    transition:.3s;\n}\n\n.unit-switch button.active{\n    background:#000;\n    color:#fff;\n}\n\ntable{\n    width:100%;\n    border-collapse:collapse;\n    overflow:hidden;\n    border-radius:10px;\n}\n\nthead{\n    background:#111;\n    color:#fff;\n}\n\nth,td{\n    padding:14px;\n    text-align:center;\n    border-bottom:1px solid #eee;\n}\n\ntbody tr:nth-child(even){\n    background:#fafafa;\n}\n\ntbody tr:hover{\n    background:#f3f3f3;\n}\n\n@media(max-width:600px){\n    th,td{\n        padding:12px 8px;\n        font-size:14px;\n    }\n}\n<\/style>\n<\/head>\n<body>\n\n<div class=\"size-chart\">\n\n    <div class=\"unit-switch\">\n        <button class=\"active\" data-unit=\"inch\">Inches<\/button>\n        <button data-unit=\"cm\">Centimeters<\/button>\n    <\/div>\n\n    <table>\n        <thead>\n            <tr>\n                <th>Size<\/th>\n                <th>Chest<\/th>\n                <th>Waist<\/th>\n                <th>Hip<\/th>\n            <\/tr>\n        <\/thead>\n        <tbody>\n            <tr>\n                <td>XS<\/td>\n                <td class=\"measure\" data-inch=\"32\">32\"<\/td>\n                <td class=\"measure\" data-inch=\"26\">26\"<\/td>\n                <td class=\"measure\" data-inch=\"34\">34\"<\/td>\n            <\/tr>\n            <tr>\n                <td>S<\/td>\n                <td class=\"measure\" data-inch=\"34\">34\"<\/td>\n                <td class=\"measure\" data-inch=\"28\">28\"<\/td>\n                <td class=\"measure\" data-inch=\"36\">36\"<\/td>\n            <\/tr>\n            <tr>\n                <td>M<\/td>\n                <td class=\"measure\" data-inch=\"36\">36\"<\/td>\n                <td class=\"measure\" data-inch=\"30\">30\"<\/td>\n                <td class=\"measure\" data-inch=\"38\">38\"<\/td>\n            <\/tr>\n            <tr>\n                <td>L<\/td>\n                <td class=\"measure\" data-inch=\"40\">40\"<\/td>\n                <td class=\"measure\" data-inch=\"34\">34\"<\/td>\n                <td class=\"measure\" data-inch=\"42\">42\"<\/td>\n            <\/tr>\n            <tr>\n                <td>XL<\/td>\n                <td class=\"measure\" data-inch=\"44\">44\"<\/td>\n                <td class=\"measure\" data-inch=\"38\">38\"<\/td>\n                <td class=\"measure\" data-inch=\"46\">46\"<\/td>\n            <\/tr>\n        <\/tbody>\n    <\/table>\n\n<\/div>\n\n<script>\nconst buttons = document.querySelectorAll(\".unit-switch button\");\nconst measures = document.querySelectorAll(\".measure\");\n\nbuttons.forEach(btn=>{\n    btn.addEventListener(\"click\",()=>{\n\n        buttons.forEach(b=>b.classList.remove(\"active\"));\n        btn.classList.add(\"active\");\n\n        const unit = btn.dataset.unit;\n\n        measures.forEach(cell=>{\n            const inch = parseFloat(cell.dataset.inch);\n\n            if(unit === \"inch\"){\n                cell.textContent = `${inch}\"`;\n            }else{\n                const cm = (inch * 2.54).toFixed(1);\n                cell.textContent = `${cm} cm`;\n            }\n        });\n\n    });\n});\n<\/script>\n\n<\/body>\n<\/html>","width":"wrapper","color_scheme":"","padding_top":0,"padding_bottom":0}}},"order":["section-divider","main-page","section_custom_code_wrWknE"]}